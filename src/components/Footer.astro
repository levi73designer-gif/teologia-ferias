---
import MulticolorBar from './MulticolorBar.astro';
---

<footer class="footer" role="contentinfo">
  <div class="container footer__inner">
    <div class="footer__logos">
      <img
        src="/images/CED-SP-LOGO.png"
        alt="Logo do Quadrangular CED-SP"
        class="footer__logo footer__logo--ced"
        width="92"
        height="80"
        loading="lazy"
      />
      <img
        src="/images/SEEC-SP-LOGO.png"
        alt="Logo da SEEC-SP"
        class="footer__logo"
        width="80"
        height="80"
        loading="lazy"
      />
    </div>
    <div class="footer__links">
      <a
        href="https://wa.me/5519984433006?text=Ol%C3%A1!%20Tenho%20interesse%20no%20curso%20Teologia%20nas%20F%C3%A9rias%20%E2%80%93%20Conhecendo%20o%20Mecanismo%20dos%20Dons%20Espirituais."
        class="footer__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contato pelo WhatsApp"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp: +55 19 98443-3006
      </a>
      <a
        href="https://instagram.com/seecsp"
        class="footer__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Perfil da SEEC-SP no Instagram"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        @seecsp
      </a>
    </div>
    <p class="footer__subtitle">
      Conhecendo o Mecanismo dos Dons Espirituais
    </p>
  </div>
  <MulticolorBar />
  <div class="footer__copyright container">
    <p>Teologia nas Férias — Quadrangular CED-SP e SEEC-SP</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--footer-bg);
    color: var(--footer-text);
    padding-block-start: var(--footer-padding-y);
    padding-inline: var(--footer-padding-x);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--footer-gap);
    text-align: center;
    padding-block-end: var(--footer-gap);
  }

  .footer__logos {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .footer__logo {
    width: 3rem;
    height: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .footer__logo--ced {
    width: 4rem;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .footer__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--footer-link-text);
    font-size: var(--font-size-body-sm);
    min-height: 2.75rem;
    transition: var(--transition-colors);
  }

  .footer__link:hover {
    color: var(--footer-link-hover-text);
  }

  .footer__subtitle {
    font-size: var(--font-size-body-sm);
    color: var(--color-neutral-gray-400);
  }

  .footer__copyright {
    padding-block: var(--space-4);
    text-align: center;
  }

  .footer__copyright p {
    font-size: var(--footer-copyright-font-size);
    color: var(--footer-copyright-text);
  }
</style>