---
import MulticolorBar from './MulticolorBar.astro';
---

<section class="hero-banner" aria-label="Imagem de destaque Teologia nas Férias 2026">
  <MulticolorBar />
  <div class="hero-banner__inner container">
    <img
      src="/images/og-image.jpg"
      alt="Teologia nas Férias 2026 — Conhecendo o Mecanismo dos Dons Espirituais"
      class="hero-banner__image"
      width="1200"
      height="630"
      fetchpriority="high"
    />
  </div>
</section>

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__inner container">
    <span class="badge badge--yellow">Teologia nas Férias</span>
    <h1 id="hero-heading" class="hero__title">
      Entenda os dons espirituais de uma vez
    </h1>
    <p class="hero__subtitle">
      Quatro sextas-feiras em julho para você compreender como os dons espirituais atuam na sua vida. Ao vivo, online e com gravação disponível.
    </p>
    <div class="hero__ctas">
      <a href="#cta-final" class="btn btn--primary">
        Quero participar
      </a>
      <a
        href="https://wa.me/5519984433006?text=Ol%C3%A1!%20Tenho%20interesse%20no%20curso%20Teologia%20nas%20F%C3%A9rias%20%E2%80%93%20Conhecendo%20o%20Mecanismo%20dos%20Dons%20Espirituais."
        class="btn btn--secondary"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Fale conosco no WhatsApp"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        Fale no WhatsApp
      </a>
    </div>
    <p class="hero__info caption">
      Sextas-feiras de julho · 19h30 · Google Meet
    </p>
  </div>
</section>

<style>
  .hero-banner {
    background: var(--hero-bg);
    overflow: hidden;
  }

  .hero-banner__inner {
    padding-block: var(--space-4);
    padding-inline: var(--hero-padding-x);
  }

  .hero-banner__image {
    width: 100%;
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    display: block;
  }

  .hero {
    background: var(--hero-bg);
    color: var(--hero-text);
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--hero-gap);
    padding-block: var(--hero-padding-y);
    padding-inline: var(--hero-padding-x);
  }

  .hero__title {
    color: var(--color-neutral-white);
    max-width: 36rem;
  }

  .hero__subtitle {
    font-size: var(--font-size-body-lg);
    line-height: var(--line-height-normal);
    color: rgba(255, 255, 255, 0.85);
    max-width: 32rem;
  }

  .hero__ctas {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    width: 100%;
  }

  @media (min-width: 768px) {
    .hero__ctas {
      flex-direction: row;
      justify-content: center;
      width: auto;
    }
  }

  .hero__ctas .btn--secondary {
    color: var(--color-neutral-white);
    border-color: var(--color-neutral-white);
  }

  .hero__ctas .btn--secondary:hover {
    color: var(--color-text-on-primary);
    background: var(--color-neutral-white);
    border-color: var(--color-neutral-white);
  }

  .hero__info {
    color: rgba(255, 255, 255, 0.7);
  }
</style>