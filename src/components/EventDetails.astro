---
const cards = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
    title: '4, 11, 18 e 25 de julho',
    subtitle: 'Todas as sextas-feiras de julho',
    color: 'var(--color-accent-red-500)',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: '19h30',
    subtitle: 'Aula ao vivo pelo Google Meet',
    color: 'var(--color-primary-500)',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`,
    title: 'Ao vivo + gravação',
    subtitle: 'Se não puder assistir, assista depois',
    color: 'var(--color-accent-purple-500)',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: 'R$ 10,00 por aula',
    subtitle: 'Sem taxas escondidas',
    color: 'var(--color-accent-yellow-600)',
  },
];
---

<section class="section section--alt" aria-labelledby="details-heading">
  <div class="container details__inner">
    <h2 id="details-heading" class="details__title">
      Informações do curso
    </h2>
    <div class="grid grid--4 details__grid">
      {cards.map((c) => (
        <div class="card details__card">
          <span class="details__icon" style={`color: ${c.color}`} set:html={c.icon} />
          <h3 class="details__card-title">{c.title}</h3>
          <p class="details__card-subtitle">{c.subtitle}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .details__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--section-gap);
  }

  .details__title {
    text-align: center;
  }

  .details__grid {
    width: 100%;
  }

  .details__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-3);
  }

  .details__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--icon-size-2xl);
    height: var(--icon-size-2xl);
    background: var(--color-neutral-gray-50);
    border-radius: var(--radius-md);
  }

  .details__icon :global(svg) {
    width: var(--icon-size-lg);
    height: var(--icon-size-lg);
  }

  .details__card-title {
    color: var(--color-text-primary);
  }

  .details__card-subtitle {
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-normal);
    color: var(--color-text-secondary);
  }
</style>