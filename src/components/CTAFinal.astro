---
---

<section class="section cta-final" id="cta-final" aria-labelledby="cta-final-heading">
  <div class="container cta-final__inner">
    <div class="cta-final__header">
      <h2 id="cta-final-heading" class="cta-final__title">
        Não deixe as férias passarem sem investir no seu crescimento
      </h2>
      <p class="cta-final__text">
        Quatro aulas. Um entendimento que muda a forma de você viver os dons espirituais. Inscreva-se agora e garanta sua vaga.
      </p>
    </div>
    <div class="cta-final__body">
      <form
        class="cta-final__form"
        action="https://script.google.com/macros/s/AKfycbzUUzKRYD7Y2cThyVVms6xKH1FJXL4FIIjY8NpRPUfpWUefz5vsUYFbIPtixLEB1gpphg/exec"
        method="POST"
        id="signup-form"
      >
        <h3 class="cta-final__form-title">Inscreva-se no curso</h3>
        <div class="form-group">
          <label for="nome" class="form-label">Nome</label>
          <input
            type="text"
            id="nome"
            name="nome"
            class="form-input"
            placeholder="Seu nome completo"
            required
            autocomplete="name"
          />
        </div>
        <div class="form-group">
          <label for="email" class="form-label">E-mail</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-input"
            placeholder="seuemail@exemplo.com"
            required
            autocomplete="email"
          />
        </div>
        <div class="form-group">
          <label for="whatsapp" class="form-label">WhatsApp</label>
          <input
            type="tel"
            id="whatsapp"
            name="whatsapp"
            class="form-input"
            placeholder="(00) 00000-0000"
            required
            autocomplete="tel"
          />
        </div>
        <button type="submit" class="btn btn--primary cta-final__submit">
          Quero participar
        </button>
        <div id="form-success" class="cta-final__success" hidden>
          <p>Pronto! Você receberá as informações do curso pelo WhatsApp. Fique atento.</p>
        </div>
        <div id="form-error" class="cta-final__error" hidden>
          <p>Não conseguimos enviar sua inscrição agora. Tente novamente em instantes ou entre em contato pelo WhatsApp.</p>
        </div>
      </form>
      <div class="cta-final__whatsapp">
        <p class="cta-final__whatsapp-text">Prefere falar direto?</p>
        <a
          href="https://wa.me/5519999531669"
          class="btn btn--whatsapp"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Abrir conversa no WhatsApp"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Falar no WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('signup-form') as HTMLFormElement;
  const successEl = document.getElementById('form-success') as HTMLElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      successEl.hidden = true;
      errorEl.hidden = true;

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const submitBtn = form.querySelector('.cta-final__submit') as HTMLButtonElement;
      const originalText = submitBtn.textContent || '';
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';

      try {
        const formData = new FormData(form);
        const data = {
          nome: formData.get('nome'),
          email: formData.get('email'),
          whatsapp: formData.get('whatsapp'),
        };

        await fetch(form.action, {
          method: 'POST',
          mode: 'no-cors',
          body: JSON.stringify(data),
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        });

        form.reset();
        successEl.hidden = false;
      } catch {
        errorEl.hidden = false;
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  }
</script>

<style>
  .cta-final {
    background: var(--color-bg-secondary);
  }

  .cta-final__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--section-gap);
  }

  .cta-final__header {
    text-align: center;
    max-width: 32rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cta-final__title {
    color: var(--color-text-primary);
  }

  .cta-final__text {
    font-size: var(--font-size-body-lg);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
  }

  .cta-final__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    width: 100%;
    max-width: 28rem;
  }

  .cta-final__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cta-final__form-title {
    text-align: center;
    color: var(--color-primary-500);
  }

  .cta-final__submit {
    width: 100%;
    margin-top: var(--space-2);
  }

  .cta-final__submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .cta-final__success {
    background: var(--color-success-bg);
    color: var(--color-success-text);
    padding: var(--space-4);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-relaxed);
  }

  .cta-final__error {
    background: var(--color-error-bg);
    color: var(--color-error-text);
    padding: var(--space-4);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-relaxed);
  }

  .cta-final__whatsapp {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .cta-final__whatsapp-text {
    font-size: var(--font-size-body-sm);
    color: var(--color-text-secondary);
  }

  .cta-final__whatsapp .btn--whatsapp {
    width: 100%;
    justify-content: center;
  }
</style>